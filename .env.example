# HubSpot config for the lead-capture form.
# These are PUBLIC identifiers (they ship in the client bundle). They are NOT
# secrets — store them as GitHub *repository variables*, not secrets.
# Copy this file to `.env` for local dev.

# Hub / portal ID (confirmed live for this account).
VITE_HUBSPOT_PORTAL_ID=21197737

# Form GUID (UUID) of the DEDICATED lead-capture form (see HUBSPOT-SETUP.md).
# Verified live: this form requires firstname, lastname, email, mobilephone, and
# sms_opt_in. Do NOT point this at the old "New talk to an expert form"
# (08426f5c-…) — it has no sms_opt_in field.
VITE_HUBSPOT_FORM_GUID=fa52f5f8-7d09-4103-921c-0146c0322cef

# Internal name of the phone property THIS FORM expects.
# Verified live against form fa52f5f8: it requires `mobilephone`. Posting `phone`
# instead returns 400 REQUIRED_FIELD. Change only if you rebuild the form to use
# the plain `phone` property.
VITE_HUBSPOT_PHONE_PROPERTY=mobilephone

# Internal name of the boolean SMS opt-in contact property (audit trail).
# Verified live: submissions land as sms_opt_in="true" on the contact record.
VITE_HUBSPOT_SMS_CONSENT_PROPERTY=sms_opt_in

# Optional: internal name of a datetime property recording when consent was given.
VITE_HUBSPOT_SMS_CONSENT_TS_PROPERTY=sms_opt_in_timestamp

# Optional: internal name of a text property recording WHICH consent wording was
# agreed to (see SMS_CONSENT_TEXT_VERSION in src/lib/hubspot.ts).
VITE_HUBSPOT_SMS_CONSENT_VERSION_PROPERTY=sms_consent_text_version

# Public legal pages shown beside the SMS consent checkbox. Carriers verify these
# resolve during 10DLC campaign registration — point them at real, live pages.
VITE_PRIVACY_URL=https://app.deedo.ai/privacy-policy
VITE_TERMS_URL=https://app.deedo.ai/terms-of-use

# ---------------------------------------------------------------------------
# Google tags. BOTH are optional — leave blank and NO Google script is loaded at
# all (zero third-party requests). Set one or both:
#
#   VITE_GTM_ID  Google Tag Manager container. Prefer this if you want to add or
#                change tags without redeploying the site.
#   VITE_GA4_ID  GA4 measurement ID, loaded directly via gtag.js. Use on its own
#                for plain analytics; skip it if GTM already fires your GA4 tag,
#                or you will double-count pageviews.
#
# The page pushes these events to dataLayer: `cta_click` (with cta + location)
# and `generate_lead` on a successful form submission.
# ---------------------------------------------------------------------------
VITE_GTM_ID=GTM-MSNV33KS
VITE_GA4_ID=

# ---------------------------------------------------------------------------
# Deployment / GitHub. These are for local tooling and reference only — the
# GitHub Actions workflow uses the repo's own context and secrets, not this file.
#
# NOTE THE MISSING VITE_ PREFIX, AND KEEP IT THAT WAY. Vite inlines every
# VITE_* variable into the public client bundle. Renaming GITHUB_TOKEN to
# VITE_GITHUB_TOKEN would publish your token to a public site on the next build.
# ---------------------------------------------------------------------------
GITHUB_REPO=ExeeAI/deedo-landing

# Custom domain for GitHub Pages. Must match public/CNAME, which Vite copies to
# dist/ so the domain survives an Actions-published artifact.
CUSTOM_DOMAIN=land.deedo.ai

# Branch Pages deploys from, and the folder it serves.
# "/" = repo root (only correct while Pages is in "deploy from a branch" mode).
# Under GitHub Actions the published artifact is dist/ and this is unused.
PAGES_BRANCH=main
PAGES_FOLDER=/

# A GitHub token (github_pat_… or gho_…) with `repo` + `workflow` scope.
# NEVER commit a real value — this file is the committed template; real values
# belong in .env, which is gitignored.
GITHUB_TOKEN=
